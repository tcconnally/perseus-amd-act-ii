# Perseus Vault x AMD Instinct - environment template
# Copy to .env and fill in. NEVER commit real credentials. .env is gitignored.

# ---------------------------------------------------------------------------
# Inference on AMD Instinct (optional)
# ---------------------------------------------------------------------------
# Fireworks AI serves open-weight models on AMD Instinct GPUs. Provide a key to
# run REAL inference in the demo; without it the demo uses a clearly-labelled
# offline stand-in and still runs end-to-end.
FIREWORKS_API_KEY=

# Open-weight model to serve on AMD (default: Llama-3.1-70B Instruct).
FIREWORKS_MODEL=accounts/fireworks/models/llama-v3p1-70b-instruct

# ---------------------------------------------------------------------------
# Memory backend (optional)
# ---------------------------------------------------------------------------
# Point this at a real `perseus-vault` binary to run the demo/benchmarks against
# the shipping Rust engine instead of the bundled CPU reference store. Leave
# unset to use the reference store (SQLite/FTS5) - both are labelled "measured".
#   Install: curl -sSf https://raw.githubusercontent.com/Perseus-Computing-LLC/perseus-vault/main/scripts/install.sh | sh
PERSEUS_VAULT_BIN=

# On-disk path for the memory DB (default: in-memory for the demo).
PERSEUS_VAULT_DB=:memory:
